# Public app port exposed on host machine
APP_PORT=8000

# Internal app port in container
# Frontend and API are both served on this same port.
HOST=0.0.0.0
SERVICE_PORT=8000

# SQLite file path inside container
DB_PATH=/data/progress_tracker.db

# Host folder for SQLite persistence (bind mount)
# Windows and Linux both support relative path here.
SQLITE_DATA_DIR=./docker-data
